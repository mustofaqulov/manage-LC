# Docker Compose Environment Variables

# Gemini API Key (required for build)
VITE_GEMINI_API_KEY=your_api_key_here

# Port to expose the application (default: 80)
PORT=80

# Image tag to use (default: latest)
IMAGE_TAG=latest

# GitHub repository name (for pulling from GHCR)
GITHUB_REPOSITORY=mustofaqulov/manage-lc
